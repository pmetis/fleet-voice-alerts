// firestore.rules
// All Firestore reads/writes go through Cloud Functions (server-side).
// The add-in browser client NEVER accesses Firestore directly.
// These rules lock down the database completely.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // No direct client access — all writes go through Cloud Functions
    // which use the default service account (bypasses these rules).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
