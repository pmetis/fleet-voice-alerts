# Fleet Voice Alerts — Environment Variables
# Copy to .env and fill in values before deploying Cloud Functions
# NEVER commit this file to version control

# ── Required ──────────────────────────────────────────────────────────────────

# 64-character hex string (32 bytes) for AES-256-GCM encryption of Twilio token
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_ENCRYPTION_KEY=

# GCP project ID (used in deploy scripts)
GCP_PROJECT=

# GCP region for Cloud Functions (e.g. us-central1, us-east1)
GCP_REGION=us-central1

# ── Add-In hosting ────────────────────────────────────────────────────────────
# URL of your GCS bucket or Cloud Run hosting the add-in static files
# Set this in addin.json and app.js (CONFIG_API_BASE)
ADDIN_HOST_URL=https://storage.googleapis.com/YOUR-BUCKET/fleet-voice-alerts

# ── Day 2+ (not needed for Day 1) ─────────────────────────────────────────────
# Anthropic API key for ACE enrichment calls
ANTHROPIC_API_KEY=

# Google Cloud TTS / STT API keys (if not using ADC)
# Usually not needed when running on Cloud Functions (uses Application Default Credentials)
